# Django Settings
EMAIL=
EMAIL_PASSWORD=

DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DEBUG=
# Example: https://your-project-ref.supabase.co
SUPABASE_URL=
# Usually "authenticated" for Supabase access tokens
SUPABASE_JWT_AUDIENCE=authenticated
# Required for projects still using HS* JWT signing
# Get this from: https://supabase.com/dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=
# Optional. Keep only on backend if you call privileged Supabase admin APIs.
SUPABASE_SERVICE_ROLE_KEY=
